---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/portfolio/ProjectCard.astro';
import { projects } from '../data/projects';
---

<Layout title="Home">
  <section class="mx-auto max-w-7xl px-8 py-24">
    <p class="text-sm font-semibold uppercase tracking-[0.3em] text-blue-400">
      Portfolio + Product Lab
    </p>

    <h1 class="mt-6 max-w-4xl text-6xl font-bold tracking-tight">
      Designing clean interfaces and building useful web tools.
    </h1>

    <p class="mt-8 max-w-2xl text-xl text-slate-300">
      A personal site for selected work, experiments, and dashboard-style web applications.
    </p>
  </section>

  <section class="mx-auto max-w-7xl px-8 pb-24">
    <h2 class="text-3xl font-bold">Featured Projects</h2>

	<div class="mt-8 grid gap-6 md:grid-cols-3">
	{projects.map((project) => (
		<ProjectCard
		title={project.title}
		description={project.description}
		href={project.href}
		tags={project.tags}
		/>
	))}
	</div>

  </section>
</Layout>