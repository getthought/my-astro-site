---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Dashboard">
  <section class="mx-auto max-w-7xl px-8 py-20">
    <h1 class="text-5xl font-bold">Dashboard</h1>

    <div class="mt-12 grid gap-6 md:grid-cols-3">
      <div class="rounded-xl border border-slate-800 p-6">
        <h2 class="text-xl font-semibold">Project Status</h2>
        <p class="mt-4 text-slate-400">
          Future dashboard widget
        </p>
      </div>

      <div class="rounded-xl border border-slate-800 p-6">
        <h2 class="text-xl font-semibold">Analytics</h2>
        <p class="mt-4 text-slate-400">
          Future dashboard widget
        </p>
      </div>

      <div class="rounded-xl border border-slate-800 p-6">
        <h2 class="text-xl font-semibold">Activity</h2>
        <p class="mt-4 text-slate-400">
          Future dashboard widget
        </p>
      </div>
    </div>
  </section>
</Layout>